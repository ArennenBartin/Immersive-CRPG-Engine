{
  "name": "crpg-engine-feature-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "typecheck": "tsc --noEmit",
    "build:client": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build": "npm run typecheck && npm run build:client && npm run build:server",
    "preview": "vite preview",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test:engine": "tsx scripts/test-engine-core.ts",
    "test:chemistry": "tsx scripts/test-chemistry.ts",
    "test:suite": "tsx scripts/test-map-suite.ts",
    "test:state": "tsx scripts/test-alderamontico-state.ts",
    "test:package-roundtrip": "tsx scripts/test-package-roundtrip.ts",
    "test:map-contract": "tsx scripts/test-map-contract.ts",
    "test:map-validator": "tsx scripts/test-map-validator.ts",
    "test:save-roundtrip": "tsx scripts/test-save-roundtrip.ts",
    "test:studio-runtime-support": "tsx scripts/test-studio-runtime-support.ts",
    "test:encounter-contract": "tsx scripts/test-encounter-contract.ts",
    "test:entity-state": "tsx scripts/test-entity-state.ts",
    "test:dungeon": "tsx scripts/test-dungeon.ts",
    "test:all": "npm run test:engine && npm run test:chemistry && npm run test:state && npm run test:suite && npm run test:package-roundtrip && npm run test:map-contract && npm run test:map-validator && npm run test:save-roundtrip && npm run test:studio-runtime-support && npm run test:encounter-contract && npm run test:entity-state && npm run test:dungeon",
    "profile:fog": "tsx scripts/profile-fog-los.ts",
    "profile:save": "tsx scripts/profile-save-size.ts",
    "audit:maps": "tsx scripts/audit-maps.ts",
    "audit:combat": "tsx scripts/audit-combat.ts",
    "audit:animated-sprites": "node scripts/audit-animated-sprites.mjs",
    "audit:overworld": "tsx scripts/audit-overworld.ts",
    "audit:overworld-assets": "tsx scripts/audit-overworld-assets.ts",
    "audit:references": "tsx scripts/audit-references.ts",
    "audit:map-validator": "tsx scripts/audit-map-validator.ts --fixture",
    "audit:legacy-imports": "tsx scripts/audit-legacy-imports.ts",
    "audit:studio-runtime-support": "tsx scripts/audit-studio-runtime-support.ts",
    "audit:dungeon": "tsx scripts/audit-dungeon.ts",
    "audit:dungeon-seeds": "tsx scripts/audit-dungeon-seeds.ts",
    "profile:dungeon": "tsx scripts/profile-dungeon.ts",
    "audit:all": "npm run audit:maps && npm run audit:combat && npm run audit:animated-sprites && npm run audit:overworld-assets && npm run audit:references && npm run audit:map-validator && npm run audit:legacy-imports && npm run audit:studio-runtime-support && npm run audit:dungeon",
    "verify": "npm run verify:dungeon-readiness",
    "verify:dungeon-readiness": "npm run typecheck && npm run lint && npm run build && npm run test:all && npm run audit:all && npm run profile:fog && npm run profile:save",
    "art:extract-oblique-tiles": "tsx scripts/extract-oblique-terrain-atlas.ts",
    "art:extract-oblique-structures": "tsx scripts/extract-oblique-structure-atlas.ts",
    "art:extract-oblique-barriers": "tsx scripts/extract-oblique-barrier-atlas.ts",
    "art:extract-oblique-props": "tsx scripts/extract-oblique-prop-atlas.ts",
    "art:extract-player": "tsx scripts/extract-intercessor-player-atlas.ts",
    "art:optimize-character-gifs": "node scripts/optimize-character-gifs.mjs"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "gifuct-js": "^2.1.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "postprocessing": "^6.39.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "three": "^0.184.0",
    "vite": "^6.2.3",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/three": "^0.184.1",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
